PORT=4000

# Prisma (must match POSTGRES_*). Use localhost when the API runs on the host; use host "db" when the API runs in Docker Compose.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowledge_hub?schema=public
# DATABASE_URL=postgresql://postgres:postgres@db:5432/knowledge_hub?schema=public

CRYPT_SALT=10
JWT_SECRET_KEY=secret123123
JWT_SECRET_REFRESH_KEY=secret123123
TOKEN_EXPIRE_TIME=1h
TOKEN_REFRESH_EXPIRE_TIME=24h

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=knowledge_hub
POSTGRES_HOST=db
POSTGRES_PORT=5432
