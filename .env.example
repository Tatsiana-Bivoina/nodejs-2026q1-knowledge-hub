PORT=4000

# Prisma (must match POSTGRES_*). Local Nest: localhost. Docker Compose overrides DATABASE_URL to host "db" in docker-compose.yml.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowledge_hub?schema=public

CRYPT_SALT=10
JWT_SECRET_KEY=secret123123
JWT_SECRET_REFRESH_KEY=secret123123
TOKEN_EXPIRE_TIME=1h
TOKEN_REFRESH_EXPIRE_TIME=24h
AUTH_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=60000
LOG_LEVEL=log
LOG_MAX_FILE_SIZE=1024

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=knowledge_hub
POSTGRES_HOST=db
POSTGRES_PORT=5432

GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-002
AI_RATE_LIMIT_RPM=20
AI_CACHE_TTL_SEC=300
AI_CONVERSATION_TTL_SEC=900
AI_PROXY_HOST=127.0.0.1
AI_PROXY_PORT=8888
AI_PROXY_PROTOCOL=http
RAG_VECTOR_DB_PROVIDER=qdrant
RAG_VECTOR_DB_URL=http://vectordb:6333
RAG_VECTOR_COLLECTION=knowledge_hub_articles
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=200
RAG_CONVERSATION_MAX_MESSAGES=20
