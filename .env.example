PORT=4000

# Prisma (must match POSTGRES_*). Local Nest: localhost. Docker Compose overrides DATABASE_URL to host "db" in docker-compose.yml.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowledge_hub?schema=public

CRYPT_SALT=10
JWT_SECRET_KEY=secret123123
JWT_SECRET_REFRESH_KEY=secret123123
TOKEN_EXPIRE_TIME=1h
TOKEN_REFRESH_EXPIRE_TIME=24h
AUTH_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=60000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=knowledge_hub
POSTGRES_HOST=db
POSTGRES_PORT=5432
